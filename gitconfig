[push]
    default = tracking
[color]
    diff = auto
    status = auto
    branch = auto
    interactive = auto
[diff]
    renamelimit = 0
	compactionHeuristic = true
[merge]
    summary = true
    conflictStyle = zdiff3
[alias]
    st = status
    cm = commit
    br = branch -v
    co = checkout
    lg = log --pretty=format:\"%h %Cblue%ar %Cgreen%an%Creset: %s %Cred%d\"
    ll = log -10 --pretty=format:\"%h %Cblue%ar %Cgreen%an%Creset: %s %Cred%d\"
    gr = log --graph --pretty=format:\"%Cred%h %Cblue%ar%Creset %Cgreen%an%Creset %s %Cred%d\"
[core]
    excludesfile = ~/.gitignore
    pager = delta
[interactive]
    diffFilter = delta --color-only
[delta]
    navigate = true  # use n and N to move between diff sections
    dark = true      # or light = true, or omit for auto-detection
[github]
	user = miros
[user]
	name = miros
	email = mirosm@mirosm.ru
	signingkey = ~/.ssh/id_rsa_github.pub
[pull]
	rebase = true
[url "git@github.com:"]
	insteadOf = https://github.com/
[init]
	defaultBranch = main
[gpg]
	format = ssh
[commit]
	gpgsign = true
[branch]
	sort = -committerdate
[init]
	defaultBranch = main
[include]
    path = ~/.gitconfig_local
[trace2]
	eventTarget = af_unix:stream:/Users/miroslavmalkin/.git-ai/internal/daemon/trace2.sock
	eventNesting = 0
