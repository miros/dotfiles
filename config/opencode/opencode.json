{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "tavily": {
      "type": "remote",
      "url": "https://mcp.tavily.com/mcp/?tavilyApiKey=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",
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest"],
      "enabled": false
    }
  },
  "permission": {
    "skill": {
      "*": "allow",
      "mp-*": "ask"
    }
  },
  "command": {
    "goal": {
      "description": "Set a session-scoped goal and auto-continue until complete.",
      "template": "$ARGUMENTS",
      "agent": "build"
    }
  },
  "plugin": [
    ["@plannotator/opencode@latest", {
      "workflow": "manual"
    }],
    "opencode-goal-plugin"
  ]
}
